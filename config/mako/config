#
font=JetBrainsMono Nerd Font 10
max-history=10

# Геометрия и скругление
width=300
height=150
margin=20
padding=15
border-size=1
border-radius=10

# Цвета (темная тема)
background-color=#1e1e2e99
text-color=#cdd6f4
border-color=#89b4fa

# Время отображения (мс)
default-timeout=5000
ignore-timeout=1
icons=1


# Специфичные настройки для критических уведомлений
[urgency=high]
border-color=#f38ba8
default-timeout=9000

[urgency=low]
border-color=#117900


