{
  "layer": "top",
  "position": "top",
  "spacing": 2,

  "modules-left": ["custom/launcher", "hyprland/workspaces", "hyprland/window"],

  "custom/launcher": {
    "format": "<span size='x-large'>ο¨Δ</span>",
    "on-click": "nwg-drawer",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "active-only": false,
    "on-click": "activate",
    "format": "{id}",
    "persistent-workspaces": {}
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 120,
    "separate-outputs": true
  },

  "modules-center": ["network"],

  "network": {
    "format-wifi": "ο΅Ϊ   {essid}",
    "tooltip-format-wifi": "{bandwidthDownBits:>} σΑΕΓ {bandwidthUpBits:>} σΑΕΘ",
    "format-ethernet": "σΑàÄ {bandwidthDownBits:>} σΑΕΓ {bandwidthUpBits:>} σΑΕΘ",
    "format-disconnected": "ο¹± Disconnected",
    "on-click": "networkmanager_dmenu",
    "interval": 2
  },

  "modules-right": [
    "custom/recorder",
    "hyprland/language",
    "idle_inhibitor",
    "cpu",
    "backlight",
    "pulseaudio",
    "temperature",
    "battery",
    "clock",
    "tray",
    "custom/power"
  ],

  "hyprland/language": {
    "format": "{}",
    "format-ru": "\ud83c\uddf7\ud83c\uddfa",
    "format-en": "\ud83c\uddfa\ud83c\uddf8",
    "on-click": "hyprctl switchxkblayout current next",
    "keyboard-name": "apple-inc.-apple-internal-keyboard-/-trackpad"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ο¹°",
      "deactivated": "ο¹Α"
    }
  },

  "cpu": {
    "interval": 5,
    "format": "ο£Φ {usage:>3}%",
    "on-click": "alacritty -e btop"
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["σΑ³Α", "σΑΣû", "σΑΣü", "σΑΣ†", "σΑΣΓ", "σΑΣΔ", "σΑΣΘ", "σΑΣΛ", "σΑΣΞ"],
    "on-scroll-down": "brightnessctl set 5%-",
    "on-scroll-up": "brightnessctl set +5%"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "σΑùü muted",
    "format-icons": {
      "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
    },
    "on-click": "pavucontrol"
  },

  "battery": {
    "states": { "warning": 30, "critical": 15 },
    "format": "{icon} {capacity}%",
    "format-charging": "ο΅Π {capacity}%",
    "format-icons": ["οâ³", "οâÉ", "οâ²", "οâ¹", "οâÄ"],
    "interval": 5
  },

  "clock": {
    "format": "σΑÖê {:%H:%M}",
    "format-alt": "σΑÖê {:%a %d %b %H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "on-scroll": 1,
      "format": {
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    }
  },

  "tray": {
    "icon-size": 16,
    "spacing": 10
  },

  "custom/power": {
    "format": "βèΜ",
    "on-click": "~/.config/hypr/scripts/power_menu.sh",
    "tooltip": false
  },

  "temperature": {
    "thermal-zone": 1,
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "critical-threshold": 80,
    "format-critical": "{temperatureC}¬ΑC ο΄΅",
    "format": "{temperatureC}¬ΑC ο΄â"
  },

  "custom/recorder": {
    "format": "{}",
    "return-type": "json",
    "interval": 2, // –û–Ω―Ä–Α―à–Η–≤–Α–Β–Φ ―Ä–Α–Ζ –≤ 2 ―¹–Β–Κ―É–Ϋ–¥―΄ –¥–Μ―è –Ϋ–Α–¥–Β–Ε–Ϋ–Ψ―¹―²–Η
    "exec": "if pgrep -x wf-recorder > /dev/null; then echo '{\"text\": \"σΑë΄\", \"class\": \"recording\", \"tooltip\": \"–‰–¥–Β―² –Ζ–Α–Ω–Η―¹―¨...\"}'; else echo '{\"text\": \"σΑë΄\", \"class\": \"stopped\"}'; fi",
    "on-click": "~/.local/bin/record-script.sh",
    "signal": 8
  }
}
